{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/enforce-pnpm.cjs",
    "build:web": "pnpm run typecheck:libs && pnpm --filter @workspace/devether build",
    "build:server": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server build",
    "start:server": "pnpm --filter @workspace/api-server start",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
